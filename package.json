{
  "name": "vector-db",
  "version": "1.0.0",
  "description": "Demo vector database application using Zvec library",
  "main": "src/index.js",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:client": "npm --prefix client run dev",
    "dev:all": "concurrently -n server,client -c blue,green \"npm run dev\" \"npm run dev:client\"",
    "build": "npm --prefix client run build",
    "test": "node --test tests/pdfService.test.js",
    "check": "npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandy13869/vector-db.git"
  },
  "keywords": [
    "vector-database",
    "zvec",
    "alibaba",
    "ai",
    "embedding"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/sandy13869/vector-db/issues"
  },
  "homepage": "https://github.com/sandy13869/vector-db#readme",
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "@zvec/zvec": "^0.5.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "faiss-node": "^0.5.1",
    "helmet": "^8.0.0",
    "langchain": "^1.5.0",
    "morgan": "^1.10.0",
    "motion": "^12.40.0",
    "multer": "^1.4.5-lts.2",
    "pdf-parse": "^1.1.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
